{
  "machine": "fan",

  "data_root": "data/raw",
  "out_root": "extract/features",

  "train_snr": ["-6db", "0db", "6db"],
  "test_snr": ["-6db", "0db", "6db"],
  "train_ratio": 0.8,
  "seed": 42,

  "features": ["stft", "logmel", "mfcc", "hc", "chroma"],

  "mfcc": {
    "sr": 16000,
    "n_mfcc": 20,
    "n_fft": 1024,
    "hop_length": 512,
    "stats": ["mean", "std"]
  },

  "logmel": {
    "sr": 16000,
    "n_fft": 1024,
    "hop": 512,
    "n_mels": 64,
    "stats": ["mean", "std"]
  },

  "stft": {
    "sr": 16000,
    "n_fft": 1024,
    "hop_length": 512
  },

  "handcrafted": {
    "sr": 16000,
    "n_fft": 1024,
    "hop_size": 256,
    "roll_percent": 0.65,
    "stats": ["mean", "std", "max"]
  },

  "chroma": {
    "sr": 16000,
    "n_fft": 1024,
    "hop_length": 512,
    "stats": ["mean", "std"]
  },

  "svm": {
    "kernel": "rbf",
    "nu": 0.15,
    "gamma": "scale",
    "pca": 0.95,
    "scale": true,
    "threshold_quantile": 0.65
  },

  "gmm": {
    "n_components": 8,
    "covariance_type": "full",
    "reg_covar": 1e-6,
    "scale": true,
    "pca": 0.95,
    "threshold_quantile": 0.65
  },

  "iso": {
    "n_estimators": 400,
    "contamination": 0.05,
    "scale": true,
    "pca": 0.95
  },

  "metrics": {
    "threshold_mode": "manual",
    "threshold_quantile": 0.65
  }
}